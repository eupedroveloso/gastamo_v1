// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// DATABASE_URL is configured in prisma.config.ts (Prisma 7).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Family {
  id        String       @id @default(cuid())
  name      String
  createdAt DateTime     @default(now())
  users     User[]
  expenses  Expense[]
  settings  AppSettings?
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  familyId     String
  family       Family   @relation(fields: [familyId], references: [id])
  createdAt    DateTime @default(now())
}

model Expense {
  id                 String   @id @default(cuid())
  date               String
  time               String
  description        String
  value              Decimal  @db.Decimal(12, 2)
  responsible        String
  card               String
  category           String
  type               String
  installmentCurrent Int?
  installmentTotal   Int?
  createdAt          DateTime @default(now())
  familyId           String
  family             Family   @relation(fields: [familyId], references: [id])
}

model AppSettings {
  id         String @id @default(cuid())
  familyId   String @unique
  family     Family @relation(fields: [familyId], references: [id])
  members    Json
  budgets    Json
  categories Json
  cards      Json
}
